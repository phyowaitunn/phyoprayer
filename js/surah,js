const params = new URLSearchParams(window.location.search);

const surah = params.get("surah");

const title = document.getElementById("surahTitle");

const container = document.getElementById("ayahList");

const audio = document.getElementById("audioPlayer");

async function loadSurah(){

try{

const response =
await fetch(`https://api.quran.com/api/v4/chapters/${surah}/verses?translations=131&language=en`);

const data = await response.json();

title.innerText = "Surah " + surah;

container.innerHTML="";

data.verses.forEach(v => {

container.innerHTML += `

<div class="ayah-card">

<div class="ayah-ar">

${v.text_uthmani}

</div>

<div class="ayah-en">

${v.translations[0].text}

</div>

<button onclick="playAudio(${v.id})" class="play-btn">

🔊 Play

</button>

</div>

`;

});

}catch(err){

title.innerText="Failed to load Surah";

}

}

loadSurah();


function playAudio(id){

audio.src =
`https://verses.quran.com/Alafasy/mp3/${id}.mp3`;

audio.play();

}
