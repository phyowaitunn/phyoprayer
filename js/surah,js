const params = new URLSearchParams(window.location.search);
const surahNumber = params.get("surah");

const title = document.getElementById("surahTitle");
const ayahList = document.getElementById("ayahList");
const audio = document.getElementById("audioPlayer");

if(!surahNumber){
title.innerText = "Surah not found";
}

async function loadSurah(){

try{

const res = await fetch(`https://api.alquran.cloud/v1/surah/${surahNumber}`);
const data = await res.json();

const surah = data.data;

title.innerText = surah.englishName + " (" + surah.name + ")";

ayahList.innerHTML="";

surah.ayahs.forEach(ayah => {

const card = document.createElement("div");
card.className="ayah-card";

card.innerHTML = `

<div class="ayah-ar">
${ayah.text}
</div>

<div class="ayah-actions">
<button onclick="playAudio(${ayah.number})">🔊 Play</button>
</div>

`;

ayahList.appendChild(card);

});

}catch(e){

title.innerText="Failed to load Surah";

}

}

loadSurah();


function playAudio(num){

audio.src =
`https://cdn.islamic.network/quran/audio/128/ar.alafasy/${num}.mp3`;

audio.play();

}
