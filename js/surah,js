const params = new URLSearchParams(window.location.search);
const surahNumber = params.get("surah");

const title = document.getElementById("surahTitle");
const ayahList = document.getElementById("ayahList");
const audioPlayer = document.getElementById("audioPlayer");

async function loadSurah() {

try {

const res = await fetch(`https://api.alquran.cloud/v1/surah/${surahNumber}/editions/quran-uthmani`);

const data = await res.json();

const surah = data.data[0];

title.innerText = surah.englishName + " - " + surah.name;

ayahList.innerHTML = "";

surah.ayahs.forEach(ayah => {

const card = document.createElement("div");
card.className = "ayah-card";

card.innerHTML = `

<div class="ayah-ar">
${ayah.text}
</div>

<button class="play-btn" onclick="playAudio(${ayah.number})">
🔊 Play
</button>

`;

ayahList.appendChild(card);

});

} catch (error) {

title.innerText = "Failed to load Surah";

}

}

loadSurah();


function playAudio(num) {

audioPlayer.src =
`https://cdn.islamic.network/quran/audio/128/ar.alafasy/${num}.mp3`;

audioPlayer.play();

}
