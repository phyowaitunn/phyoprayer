const params = new URLSearchParams(window.location.search);
const surah = params.get("surah");

if(!surah){
document.getElementById("surahTitle").innerText="Surah not found";
}

fetch(`https://api.alquran.cloud/v1/surah/${surah}`)
.then(res=>res.json())
.then(data=>{

const surahData = data.data;

document.getElementById("surahTitle").innerText =
surahData.englishName;

const container = document.getElementById("ayahList");

surahData.ayahs.forEach(ayah=>{

container.innerHTML += `

<div class="ayah-card">

<div class="ayah-ar">
${ayah.text}
</div>

<div class="ayah-actions">

<button onclick="playAudio(${ayah.number})">
🔊 Play
</button>

</div>

</div>

`;

});

});

function playAudio(id){

const player = document.getElementById("audioPlayer");

player.src =
`https://cdn.islamic.network/quran/audio/128/ar.alafasy/${id}.mp3`;

player.play();

}
