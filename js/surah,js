const params = new URLSearchParams(window.location.search);
const surah = params.get("surah");

const title = document.getElementById("surahTitle");
const container = document.getElementById("ayahList");
const audio = document.getElementById("audioPlayer");

async function loadSurah(){

try{

const res = await fetch(`https://api.alquran.cloud/v1/surah/${surah}`);

const data = await res.json();

const surahData = data.data;

title.innerText = surahData.englishName + " - " + surahData.name;

container.innerHTML="";

surahData.ayahs.forEach(a=>{

container.innerHTML += `

<div class="ayah-card">

<div class="ayah-ar">
${a.text}
</div>

<div class="ayah-actions">

<button onclick="playAudio(${a.number})">
🔊 Play
</button>

</div>

</div>

`;

});

}catch(e){

title.innerText="Failed to load Surah";

}

}

loadSurah();


function playAudio(num){

audio.src =
`https://cdn.islamic.network/quran/audio/128/ar.alafasy/${num}.mp3`;

audio.play();

}
